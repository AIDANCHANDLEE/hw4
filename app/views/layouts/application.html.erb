<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="navbar-brand ms-3">
        <a class="navbar-brand" href="/">Home</a>
      </div>
      <div class="ms-auto me-3 d-flex align-items-center">
        <% if current_user %>
          <span class="text-light me-3">Logged in as: <%= current_user["username"] %></span>
          <%= button_to "Logout", "/logout", method: :delete, class: "btn btn-outline-light btn-sm" %>
        <% else %>
          <a href="/login" class="btn btn-outline-light btn-sm me-2">Login</a>
          <a href="/users/new" class="btn btn-light btn-sm">Signup</a>
        <% end %>
      </div>
    </nav>

    <div class="container mt-4">
      <% if flash["notice"] %>
        <div class="alert alert-info"><%= flash["notice"] %></div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
